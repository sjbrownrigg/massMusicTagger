# Copy this file to .env and fill in your values.
# docker compose automatically reads .env from the same directory.

# Directory containing your music library (source + sorted subdirs inside).
# In WSL2: mount your NFS/CIFS share first, then point here.
MUSIC_DIR=/mnt/music

# Directory where you copied docker/config/ (personal config + credentials).
CONFIG_DIR=/mnt/nas/docker/mmt/config

# Timezone for log timestamps.
TZ=Europe/London
